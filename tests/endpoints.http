###############################################################################
# 0 — Unauthenticated / setup
###############################################################################

### Health check — expect 200
GET {{base}}/health

### Dev JWKS — expect 200 with RSA public key
GET {{base}}/dev/jwks

### No auth — expect 401
GET {{base}}/api/v1/users/me

### Staff stats — expect 200
GET {{base}}/api/v1/stats
Authorization: Bearer {{staff_token}}

###############################################################################
# 1 — Users
###############################################################################

### GET /users/me (student)
GET {{base}}/api/v1/users/me
Authorization: Bearer {{student_token}}

### GET /users (staff only) — expect 200
GET {{base}}/api/v1/users
Authorization: Bearer {{staff_token}}

### GET /users (student) — expect 403
GET {{base}}/api/v1/users
Authorization: Bearer {{student_token}}

###############################################################################
# 2 — Spaces
###############################################################################

### POST /spaces (staff) — expect 201
POST {{base}}/api/v1/spaces
Authorization: Bearer {{staff_token}}
Content-Type: application/json

{
  "number": "D402",
  "type": "classroom",
  "block": "D",
  "campus": "Pici",
  "department": "Ciência da Computação",
  "capacity": 30,
  "closedFrom": "22:00",
  "closedTo": "07:00"
}

### POST /spaces (student) — expect 403
POST {{base}}/api/v1/spaces
Authorization: Bearer {{student_token}}
Content-Type: application/json

{
  "number": "X999",
  "type": "classroom",
  "block": "X",
  "campus": "Pici",
  "department": "Ciência da Computação",
  "capacity": 10
}

### GET /spaces — expect list
GET {{base}}/api/v1/spaces
Authorization: Bearer {{student_token}}

### GET /spaces filtered by department
GET {{base}}/api/v1/spaces?department=Ciência da Computação&page=1&limit=10
Authorization: Bearer {{student_token}}

### GET /spaces/:id — expect space + equipment
GET {{base}}/api/v1/spaces/00000000-0000-0000-0000-000000000011
Authorization: Bearer {{student_token}}

### GET /spaces/:id/availability — expect morning/afternoon/evening
GET {{base}}/api/v1/spaces/00000000-0000-0000-0000-000000000011/availability?date=2026-06-10
Authorization: Bearer {{student_token}}

### GET /spaces/:id/availability — missing date — expect 400
GET {{base}}/api/v1/spaces/00000000-0000-0000-0000-000000000011/availability
Authorization: Bearer {{student_token}}

### PUT /spaces/:id (staff) — expect 200
PUT {{base}}/api/v1/spaces/00000000-0000-0000-0000-000000000011
Authorization: Bearer {{staff_token}}
Content-Type: application/json

{
  "capacity": 45
}

###############################################################################
# 3 — Equipment
###############################################################################

### POST /equipment (staff) — expect 201
POST {{base}}/api/v1/equipment
Authorization: Bearer {{staff_token}}
Content-Type: application/json

{
  "assetId": "2020002660",
  "spaceId": "00000000-0000-0000-0000-000000000011",
  "name": "Quadro Interativo SMART",
  "type": "display",
  "status": "working"
}

### PATCH /equipment/:id/status (maintenance) — expect 200
PATCH {{base}}/api/v1/equipment/00000000-0000-0000-0000-000000000021/status
Authorization: Bearer {{maintenance_token}}
Content-Type: application/json

{
  "status": "broken",
  "notes": "Lâmpada queimada, aguardando reposição"
}

### PATCH /equipment/:id/status (student) — expect 403
PATCH {{base}}/api/v1/equipment/00000000-0000-0000-0000-000000000021/status
Authorization: Bearer {{student_token}}
Content-Type: application/json

{ "status": "working" }

### GET /equipment/space/:spaceId
GET {{base}}/api/v1/equipment/space/00000000-0000-0000-0000-000000000011
Authorization: Bearer {{student_token}}

###############################################################################
# 4 — Reservations
###############################################################################

### POST /reservations (student) — expect 201
POST {{base}}/api/v1/reservations
Authorization: Bearer {{student_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000012",
  "date": "2026-06-10",
  "startTime": "09:00",
  "endTime": "10:00"
}

### POST /reservations (student) — duplicate — expect 409
POST {{base}}/api/v1/reservations
Authorization: Bearer {{student_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000012",
  "date": "2026-06-10",
  "startTime": "09:00",
  "endTime": "10:00"
}

### POST /reservations (maintenance) — expect 403
POST {{base}}/api/v1/reservations
Authorization: Bearer {{maintenance_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000011",
  "date": "2026-06-11",
  "startTime": "14:00",
  "endTime": "15:00"
}

### POST /reservations/recurring (professor) — expect 201
POST {{base}}/api/v1/reservations/recurring
Authorization: Bearer {{professor_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000011",
  "startDate": "2026-06-02",
  "endDate": "2026-07-28",
  "dayOfWeek": 2,
  "startTime": "14:00",
  "endTime": "15:00",
  "description": "Aula de Programação Orientada a Objetos — turma 2026.1"
}

### POST /reservations/recurring (student) — expect 403
POST {{base}}/api/v1/reservations/recurring
Authorization: Bearer {{student_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000011",
  "startDate": "2026-06-02",
  "endDate": "2026-06-30",
  "dayOfWeek": 3,
  "startTime": "09:00",
  "endTime": "10:00",
  "description": "não autorizado"
}

### GET /reservations/mine (student)
GET {{base}}/api/v1/reservations/mine
Authorization: Bearer {{student_token}}

### GET /reservations/space/:spaceId
GET {{base}}/api/v1/reservations/space/00000000-0000-0000-0000-000000000012
Authorization: Bearer {{student_token}}

### GET /reservations/space/:spaceId filtered by date
GET {{base}}/api/v1/reservations/space/00000000-0000-0000-0000-000000000012?date=2026-06-10
Authorization: Bearer {{student_token}}

### PATCH /reservations/:id/cancel — replace :id with a real reservation UUID from above
# PATCH {{base}}/api/v1/reservations/<id>/cancel
# Authorization: Bearer {{student_token}}

###############################################################################
# 5 — Blockings
###############################################################################

### POST /blockings (staff) — expect 201
POST {{base}}/api/v1/blockings
Authorization: Bearer {{staff_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000013",
  "date": "2026-06-15",
  "startTime": "10:00",
  "endTime": "12:00",
  "reason": "Reunião do Conselho Departamental",
  "blockType": "administrative"
}

### POST /blockings (maintenance) — maintenance type — expect 201
POST {{base}}/api/v1/blockings
Authorization: Bearer {{maintenance_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000012",
  "date": "2026-06-20",
  "startTime": "14:00",
  "endTime": "16:00",
  "reason": "Instalação de novo ar condicionado",
  "blockType": "maintenance"
}

### POST /blockings (student) — expect 403
POST {{base}}/api/v1/blockings
Authorization: Bearer {{student_token}}
Content-Type: application/json

{
  "spaceId": "00000000-0000-0000-0000-000000000011",
  "date": "2026-06-16",
  "startTime": "19:00",
  "endTime": "20:00",
  "reason": "não autorizado",
  "blockType": "administrative"
}

### GET /blockings/space/:spaceId
GET {{base}}/api/v1/blockings/space/00000000-0000-0000-0000-000000000013
Authorization: Bearer {{student_token}}

### PATCH /blockings/:id/remove — replace :id with a real blocking UUID from above
# PATCH {{base}}/api/v1/blockings/<id>/remove
# Authorization: Bearer {{staff_token}}

